@model TechService.Models.Entities.AppUser

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-warning text-dark rounded-top-4 py-3">
                    <h4 class="mb-0 text-center"><i class="bi bi-pencil-square"></i> Personel Bilgilerini Güncelle</h4>
                </div>

                <div class="card-body p-4 bg-light">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger rounded-3 text-center">@ViewBag.ErrorMessage</div>
                    }

                    <form asp-action="Edit" asp-controller="Staff" method="post">
                        <!-- Güncelleme işlemi için ID'yi gizli olarak yolluyoruz -->
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Kullanıcı Adı</label>
                            <input type="text" asp-for="Username" class="form-control form-control-lg shadow-sm" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Yeni Şifre Belirle (Değiştirmeyecekseniz boş bırakın)</label>

                            <input type="text" asp-for="Password" class="form-control form-control-lg shadow-sm"
                                   placeholder="Mevcut şifre gizlenmiştir..."
                                   minlength="6" maxlength="10"
                                   pattern="\d*" title="Şifre sadece rakamlardan oluşmalıdır!" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Sistemdeki Rolü</label>
                            <select asp-for="Role" class="form-select form-select-lg shadow-sm" required>
                                <option value="Employee">Personel</option>
                                <option value="Admin">Yönetici</option>
                            </select>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold shadow-sm">Değişiklikleri Kaydet</button>
                            <a href="/Staff/Index" class="btn btn-outline-secondary">İptal ve Geri Dön</a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>