@{
    // Bu sayfanın sitenin genel Layout'unu kullanmamasını (tam ekran olmasını) sağlıyoruz
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Teknik Servis</title>
    <!-- Projemizdeki Bootstrap CSS'i çağırıyoruz -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .bg-image {
            background-image: url('/arkaplan.jpg');
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            height: 100vh;
            display: flex;
            align-items: center; /* Kutuyu dikeyde ortalar */
            justify-content: center; /* Kutuyu yatayda ortalar */
        }

        .login-card {
            background: rgba(255, 255, 255, 0.85); /* Hafif şeffaf beyaz */
            backdrop-filter: blur(10px); /* Arka planı bulanıklaştırarak şık bir efekt verir */
            border-radius: 15px; /* Köşeleri yuvarlattık */
            box-shadow: 0 15px 25px rgba(0,0,0,0.5); /* Etrafına derinlik (gölge) verir */
            padding: 3rem; /* Kutunun iç boşluğunu artırarak genişlettik */
            width: 100%;
            max-width: 450px; /* Kutunun maksimum genişliği */
        }

            .login-card h2 {
                font-weight: 700;
                color: #2c3e50;
            }

        /* Input alanlarını (metin kutularını) büyüttük */
        .form-control {
            padding: 0.8rem;
            font-size: 1.1rem;
            border-radius: 8px;
        }

        /* Giriş Yap butonunu büyüttük ve havalı yaptık */
        .btn-login {
            padding: 0.8rem;
            font-size: 1.2rem;
            font-weight: bold;
            border-radius: 8px;
            background-color: #198754;
            transition: all 0.3s;
        }

            .btn-login:hover {
                background-color: #146c43;
                transform: translateY(-2px); /* Üzerine gelince çok hafif yukarı kalkma efekti */
            }
    </style>
</head>
<body>

    <div class="bg-image">
        <div class="login-card">
            <div class="text-center mb-4">
                <h2>Teknik Servis Girişi</h2>
                <p class="text-muted">Arıza Takip Sistemine Hoş Geldiniz</p>
            </div>

            <form asp-action="Index" asp-controller="Login" method="post">
                <div class="mb-4">
                    <label class="form-label fw-bold">Kullanıcı Adı</label>
                    <input type="text" name="username" class="form-control" placeholder="Kullanıcı adınızı girin" required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Şifre</label>
                    <input type="password" name="password" class="form-control" placeholder="Şifrenizi girin" required />
                </div>

                <!-- Şifre yanlış girilirse çıkacak uyarı -->
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger p-2 mb-4 text-center rounded-3 shadow-sm">
                        @ViewBag.ErrorMessage
                    </div>
                }
                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-success text-white btn-login">Giriş Yap</button>
                </div>
            </form>
        </div>
    </div>

</body>
</html>