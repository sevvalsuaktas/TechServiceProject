@model List<TechService.Models.Entities.DeviceIncident>

<div class="container-fluid px-4">
    <!-- Başlık ve Üst Kısım -->
    <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
        <h2 class="fw-bold text-dark m-0">Arıza Kayıtları</h2>
        <div class="d-flex align-items-center">
            <span class="me-3 fw-semibold">Hoş Geldin, @User.Identity.Name!</span>
            <a href="/Login/Logout" class="btn btn-outline-danger btn-sm">Çıkış Yap</a>
        </div>
    </div>

    <!-- Gölgeli Beyaz Kart Başlangıcı -->
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">

            <!-- Arama Formu -->
            <form method="get" asp-action="Index" class="mb-4">
                <div class="input-group input-group-lg shadow-sm rounded">
                    <input type="text" name="searchString" class="form-control border-0 bg-light" placeholder="Müşteri Adı, Cihaz Modeli veya Personel Ara..." />
                    <button type="submit" class="btn btn-primary px-4">Ara</button>
                    <a href="/Incident/Index" class="btn btn-outline-secondary px-4">Temizle</a>
                </div>
            </form>

            @if (User.IsInRole("Admin"))
            {
                <a href="/Incident/Create" class="btn btn-success mb-3 shadow-sm">
                    <i class="bi bi-plus-lg"></i> + Yeni Kayıt Ekle
                </a>
            }

            <!-- Tablo -->
            <div class="table-responsive">
                <table class="table table-hover align-middle border-top">
                    <thead class="table-dark">
                        <tr>
                            <th class="py-3">Tarih</th>
                            <th>Müşteri</th>
                            <th>Cihaz</th>
                            <th>Arıza Durumu</th>
                            <th>Atanan Personel</th>
                            <th>Cihaz Fotoğrafı</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted">@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="fw-semibold">@item.CustomerName</td>
                                <td>@item.DeviceModel</td>
                                <td>@item.IssueDescription</td>
                                <td>
                                    @if (item.AssignedUser != null)
                                    {
                                        <span class="badge bg-success fs-6 px-3 py-2 shadow-sm">@item.AssignedUser.Username</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary fs-6 px-3 py-2 shadow-sm">Atanmadı</span>
                                    }
                                </td>
                                <td>
                                    @if (item.DeviceImage != null && item.DeviceImage.Length > 0)
                                    {
                                        var base64 = Convert.ToBase64String(item.DeviceImage);
                                        var imgSrc = String.Format("data:image/jpeg;base64,{0}", base64);

                                        <img src="@imgSrc" alt="Cihaz" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;" class="shadow-sm" />
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Fotoğraf Yok</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm">
                                        <a href="/Incident/Edit/@item.Id" class="btn btn-warning btn-sm">Güncelle</a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a href="/Incident/Delete/@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">Sil</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>