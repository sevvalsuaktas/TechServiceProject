@model TechService.Models.Entities.DeviceIncident

<div class="container mt-4">
    <h2>Kaydı Güncelle</h2>

    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Müşteri Adı</label>
            <input type="text" asp-for="CustomerName" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Cihaz Modeli</label>
            <input type="text" asp-for="DeviceModel" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Arıza Açıklaması</label>
            <textarea asp-for="IssueDescription" class="form-control" rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Mevcut Resim</label> <br />
            @if (Model.DeviceImage != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.DeviceImage)" style="width:150px; border:1px solid #ddd; padding:5px;" />
            }
            else
            {
                <span class="text-muted">Resim yok</span>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Resmi Değiştir (İsteğe Bağlı)</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="mb-4">
                <label class="form-label fw-bold text-dark">Atanacak Personel</label>
                <select asp-for="AssignedUserId" class="form-select form-select-lg shadow-sm">
                    <option value="">-- Personel Seçin (Atanmadı) --</option>

                    @if (ViewBag.Employees != null)
                    {
                        foreach (var user in ViewBag.Employees)
                        {
                            <option value="@user.Id">@user.Username</option>
                        }
                    }
                </select>
            </div>
        }
        else
        {
            <input type="hidden" asp-for="AssignedUserId" />
        }

        <div class="mb-4">
            <label class="form-label fw-bold text-dark">Kayıt Durumu (Aşama)</label>
            <select asp-for="Status" class="form-select form-select-lg shadow-sm">
                <option value="Bekliyor">Bekliyor</option>
                <option value="Tamamlandı">Tamamlandı</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Değişiklikleri Kaydet</button>
        <a href="/Incident/Index" class="btn btn-secondary">Vazgeç</a>
    </form>
</div>